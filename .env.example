# ===================================================
# 服务器操作审计系统 — 环境变量配置
# 复制此文件为 .env 并按需修改
# ===================================================

# ---- 系统模式 ----
# debug:      Mock链 + SQLite，零依赖一键运行
# production: 真实FISCO BCOS + Elasticsearch
# demo | production_sim | production
AUDIT_SYSTEM_MODE=demo

# ---- 日志级别 ----
AUDIT_LOG_LEVEL=DEBUG

# ---- 批次配置 ----
# 时间窗口（分钟）
BATCH_WINDOW_MINUTES=5
# 单批次最大日志数
BATCH_MAX_LOG_COUNT=10000

# ---- 生产模式: FISCO BCOS ----
# BCOS_ENDPOINT=127.0.0.1:20200
# BCOS_CONTRACT_ADDR=0x...

# ---- 生产模式: Elasticsearch ----
# ES_HOST=localhost:9200

# ---- 采集代理 ----
# COLLECTOR_MODE=direct
# COLLECTOR_LOG_FILE=/var/log/audit/commands.log
# COLLECTOR_LISTEN_PORT=5001
# COLLECTOR_BATCH_SECS=300
# COLLECTOR_API_URL=http://127.0.0.1:5000/api/v1/audit/batch

# ---- 告警邮件（可选）----
# 不配置则静默跳过告警
# ALERT_SMTP_HOST=smtp.qq.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=your_email@qq.com
# ALERT_SMTP_PASSWORD=your_password
# ALERT_FROM_EMAIL=your_email@qq.com
# ALERT_TO_EMAILS=admin1@example.com,admin2@example.com
# ALERT_MIN_LEVEL=medium
# ALERT_USE_TLS=true
